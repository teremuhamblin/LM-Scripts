# ============================
#  SCRIPTS LINUX MINT — GITIGNORE
# ============================

# --- Fichiers système Linux ---
.DS_Store
Thumbs.db
ehthumbs.db
lost+found/

# --- Fichiers temporaires ---
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
*.old
*.orig

# --- Logs ---
*.log
logs/
log/

# --- Caches ---
.cache/
*.cache

# --- Archives ---
*.tar
*.tar.gz
*.zip
*.7z
*.rar

# --- Scripts compilés ou générés ---
*.out
*.o
*.bin

# --- Permissions / exécutions ---
*.pid
*.lock

# --- Éditeurs ---
# VSCode
.vscode/
.history/

# Vim
*.vim
*.swp
*.swo
*.swn
*.un~

# Nano
*.save

# JetBrains (si jamais)
.idea/
*.iml

# --- Python (si tu ajoutes des scripts Python plus tard) ---
__pycache__/
*.pyc
*.pyo

# --- ShellCheck / Lint ---
.shellcheck/

# --- Backups automatiques ---
*~
*#

# --- Fichiers de test ---
test-output/
tests-output/

# --- Secrets (si jamais tu en ajoutes, mais évite) ---
.env
*.env
.env.*
secrets/

# assets/.gitignore
*.xcf
*.psd
*.tmp

########################################
# CUSTOM (scripts personnels non suivis)
########################################

# Ignore entièrement le dossier custom/
custom/

# Ignore tout le contenu du dossier, récursivement
custom/*

# Autorise uniquement le README explicatif (optionnel)
!custom/README.md
